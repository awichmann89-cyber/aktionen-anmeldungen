# Neon PostgreSQL connection string (mit Pooling)
# Zu finden unter: Neon Dashboard → Ihr Projekt → Connection string
# Wichtig: "Pooled connection" verwenden für Vercel
DATABASE_URL="postgresql://user:password@ep-xyz.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Admin Passwort (beliebiger Text)
ADMIN_PASSWORD="your-secure-admin-password"

# Session Secret (zufälliger langer String, min. 32 Zeichen)
# Generieren mit: openssl rand -base64 32
SESSION_SECRET="your-random-session-secret-min-32-chars"

# Basis-URL der App (für öffentliche Links)
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"
